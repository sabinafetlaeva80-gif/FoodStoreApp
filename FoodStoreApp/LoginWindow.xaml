<Window x:Class="MMarketApp.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Вход в систему" Height="500" Width="520"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#1a1a2e">

    <Grid>
        <Border Background="White" CornerRadius="15" Width="440" Height="470" 
                VerticalAlignment="Center" HorizontalAlignment="Center">
            <Border.Effect>
                <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.3"/>
            </Border.Effect>
            <StackPanel Margin="35">
                <Border Background="#e74c3c" CornerRadius="10" Padding="15" Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="М-МАРКЕТ" FontSize="28" FontWeight="Bold" 
                                   Foreground="White" TextAlignment="Center"/>
                        <TextBlock Text="Система управления магазином" FontSize="12" Foreground="#ffcccc" 
                                   TextAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>

                <TextBlock Text="Белогорский район, с. Богатое" FontSize="11" Foreground="#95A5A6" 
                           TextAlignment="Center" Margin="0,0,0,25"/>

                <TextBlock Text="Логин" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,0,0,8"/>
                <TextBox x:Name="txtLogin" Height="42" FontSize="14" Padding="10,0"
                         BorderBrush="#bdc3c7" BorderThickness="1" VerticalContentAlignment="Center"/>

                <TextBlock Text="Пароль" FontWeight="SemiBold" Foreground="#2C3E50" Margin="0,15,0,8"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <PasswordBox x:Name="txtPassword" Height="42" FontSize="14" Padding="10,0"
                                 BorderBrush="#bdc3c7" BorderThickness="1" VerticalContentAlignment="Center"/>
                    <TextBox x:Name="txtVisiblePassword" Height="42" FontSize="14" Padding="10,0"
                             BorderBrush="#bdc3c7" BorderThickness="1" Visibility="Collapsed" VerticalContentAlignment="Center"/>
                    <Button Grid.Column="1" x:Name="btnTogglePassword" Width="42" Height="42" 
                            Margin="5,0,0,0" Cursor="Hand" Click="BtnTogglePassword_Click"
                            Background="Transparent" BorderThickness="0">
                        <TextBlock x:Name="eyeIcon" Text="👁️" FontSize="20"/>
                    </Button>
                </Grid>

                <Button x:Name="btnLogin" Height="45" FontSize="15" FontWeight="SemiBold"
                        Background="#3498DB" Foreground="White" Margin="0,25,0,0"
                        Cursor="Hand" Click="BtnLogin_Click" Content="ВОЙТИ">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="8">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <TextBlock x:Name="lblError" Text="" Foreground="#e74c3c" 
                           TextAlignment="Center" FontSize="12" Margin="0,15,0,0"/>
            </StackPanel>
        </Border>
    </Grid>
</Window>