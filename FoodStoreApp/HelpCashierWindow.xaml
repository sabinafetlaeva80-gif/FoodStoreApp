<Window x:Class="FoodStoreApp.HelpCashierWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Руководство кассира" Height="620" Width="650"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#f5f6fa">

    <Border Background="White" CornerRadius="10" Margin="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="15" ShadowDepth="0" Opacity="0.2"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Background="#2C3E50" CornerRadius="10,10,0,0" Padding="15">
                <StackPanel>
                    <TextBlock Text="Руководство кассира" FontSize="20" FontWeight="Bold"
                               Foreground="White" TextAlignment="Center"/>
                    <TextBlock Text="Инструкция по работе с системой М-Маркет"
                               FontSize="12" Foreground="#BDC3C7" TextAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Содержание -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="20">
                    <!-- Авторизация -->
                    <TextBlock Text="1. АВТОРИЗАЦИЯ" FontSize="15" FontWeight="Bold"
                               Foreground="#3498DB" Margin="0,10,0,5"/>
                    <TextBlock Text="Введите полученные от администратора логин и пароль. При успешном входе система откроет окно продавца."
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Border BorderBrush="#ECF0F1" BorderThickness="0,1" Margin="0,10"/>

                    <!-- Вкладки -->
                    <TextBlock Text="2. ВКЛАДКИ" FontSize="15" FontWeight="Bold"
                               Foreground="#3498DB" Margin="0,10,0,5"/>
                    <TextBlock Text="- Продажа - основная вкладка для оформления продаж"
                               TextWrapping="Wrap" Margin="0,0,0,3"/>
                    <TextBlock Text="- Чеки - просмотр истории оформленных чеков"
                               TextWrapping="Wrap" Margin="0,0,0,3"/>
                    <TextBlock Text="- Просроченные - список товаров с истёкшим сроком годности"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Border BorderBrush="#ECF0F1" BorderThickness="0,1" Margin="0,10"/>

                    <!-- Оформление продажи -->
                    <TextBlock Text="3. ОФОРМЛЕНИЕ ПРОДАЖИ" FontSize="15" FontWeight="Bold"
                               Foreground="#3498DB" Margin="0,10,0,5"/>
                    <TextBlock Text="3.1. Добавление товара в корзину" FontWeight="SemiBold"
                               Margin="0,5,0,3"/>
                    <TextBlock Text="- Двойным кликом по строке с товаром в каталоге"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Или выделите товар и нажмите на него"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Для поиска используйте строку поиска или фильтр по категориям"
                               TextWrapping="Wrap" Margin="10,0,0,10"/>

                    <TextBlock Text="3.2. Управление корзиной" FontWeight="SemiBold"
                               Margin="0,5,0,3"/>
                    <TextBlock Text="- Для удаления товара нажмите красный крестик напротив позиции"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Для очистки всей корзины нажмите кнопку Очистить"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Выберите способ оплаты: наличные, карта или QR-код"
                               TextWrapping="Wrap" Margin="10,0,0,10"/>

                    <TextBlock Text="3.3. Отложить чек" FontWeight="SemiBold"
                               Margin="0,5,0,3"/>
                    <TextBlock Text="- Если клиент не готов оплатить, нажмите Отложить чек"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Чек сохранится и его можно будет восстановить позже"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Для возврата нажмите Вернуть отложенный и выберите заказ"
                               TextWrapping="Wrap" Margin="10,0,0,10"/>

                    <TextBlock Text="3.4. Завершение продажи" FontWeight="SemiBold"
                               Margin="0,5,0,3"/>
                    <TextBlock Text="- Проверьте правильность набора товаров в корзине"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Нажмите кнопку ПРОДАТЬ"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Система сформирует чек и спишет товары со склада"
                               TextWrapping="Wrap" Margin="10,0,0,10"/>

                    <Border BorderBrush="#ECF0F1" BorderThickness="0,1" Margin="0,10"/>

                    <!-- История и возврат -->
                    <TextBlock Text="4. ИСТОРИЯ ЧЕКОВ И ВОЗВРАТ" FontSize="15" FontWeight="Bold"
                               Foreground="#3498DB" Margin="0,10,0,5"/>
                    <TextBlock Text="4.1. Просмотр истории"
                               TextWrapping="Wrap" Margin="0,5,0,3"/>
                    <TextBlock Text="- Перейдите на вкладку Чеки"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Выберите даты для фильтрации или оставьте пустыми"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Нажмите Поиск для обновления списка"
                               TextWrapping="Wrap" Margin="10,0,0,10"/>

                    <TextBlock Text="4.2. Возврат товара" FontWeight="SemiBold"
                               Margin="0,5,0,3"/>
                    <TextBlock Text="- Выберите чек из списка - отобразятся его детали"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Нажмите кнопку Вернуть товар"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Подтвердите операцию в диалоговом окне"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="- Остатки товаров будут восстановлены"
                               TextWrapping="Wrap" Margin="10,0,0,10"/>

                    <Border BorderBrush="#ECF0F1" BorderThickness="0,1" Margin="0,10"/>

                    <!-- Просроченные -->
                    <TextBlock Text="5. ПРОСРОЧЕННЫЕ ТОВАРЫ" FontSize="15" FontWeight="Bold"
                               Foreground="#3498DB" Margin="0,10,0,5"/>
                    <TextBlock Text="- Нажмите вкладку Просроченные для просмотра"
                               TextWrapping="Wrap" Margin="0,0,0,3"/>
                    <TextBlock Text="- Отображаются товары с истёкшим сроком годности"
                               TextWrapping="Wrap" Margin="0,0,0,3"/>
                    <TextBlock Text="- Нажмите Обновить для перезагрузки данных"
                               TextWrapping="Wrap" Margin="0,0,0,10"/>

                    <Border BorderBrush="#ECF0F1" BorderThickness="0,1" Margin="0,10"/>

                    <!-- Завершение работы -->
                    <TextBlock Text="6. ЗАВЕРШЕНИЕ РАБОТЫ" FontSize="15" FontWeight="Bold"
                               Foreground="#3498DB" Margin="0,10,0,5"/>
                    <TextBlock Text="- В конце рабочего дня нажмите кнопку Выход"
                               TextWrapping="Wrap" Margin="0,0,0,3"/>
                    <TextBlock Text="- Появится диалог с выбором:"
                               TextWrapping="Wrap" Margin="0,0,0,3"/>
                    <TextBlock Text="  - Да - закрыть смену и выйти"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="  - Нет - оставить смену открытой и выйти"
                               TextWrapping="Wrap" Margin="10,0,0,2"/>
                    <TextBlock Text="  - Отмена - отменить выход"
                               TextWrapping="Wrap" Margin="10,0,0,20"/>
                </StackPanel>
            </ScrollViewer>

            <!-- Кнопка закрытия -->
            <Border Grid.Row="2" Background="#ECF0F1" CornerRadius="0,0,10,10" Padding="10">
                <Button Content="Закрыть" Width="100" Height="35" HorizontalAlignment="Right"
                        Background="#3498DB" Foreground="White" FontWeight="SemiBold"
                        Cursor="Hand" Click="BtnClose_Click"/>
            </Border>
        </Grid>
    </Border>
</Window>