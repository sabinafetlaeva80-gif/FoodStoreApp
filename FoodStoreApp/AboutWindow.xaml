<Window x:Class="FoodStoreApp.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="О программе" Height="700" Width="700"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="White">
    <Grid Margin="0,0,0,-6">
        <StackPanel Margin="30" VerticalAlignment="Center">
            <Border Background="#e74c3c" CornerRadius="12" Padding="30" Margin="0,0,0,25">
                <StackPanel HorizontalAlignment="Center">
                    <TextBlock Text="М-МАРКЕТ" FontSize="40" FontWeight="Bold" Foreground="White" TextAlignment="Center"/>
                    <TextBlock Text="Система управления магазином" FontSize="16" Foreground="#ffcccc" TextAlignment="Center" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Версия: 1.0.0" FontSize="18" FontWeight="SemiBold" Foreground="#2c3e50" TextAlignment="Center" Margin="0,0,0,15"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock Text="Разработчик: " FontSize="15" Foreground="#7f8c8d"/>
                <TextBlock FontSize="15" Foreground="#2c3e50" FontWeight="SemiBold"><Run Language="ru-ru" Text="Фетляева Сабина Бекировна"/></TextBlock>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,8,0,0">
                <TextBlock FontSize="15" Foreground="#7f8c8d"><Run Language="ru-ru" Text="Группа:"/></TextBlock>
                <TextBlock FontSize="15" Foreground="#3498db"><Run Language="ru-ru" Text="ИСПП 23 1/9"/></TextBlock>
            </StackPanel>

            <TextBlock Text="г. Белогорский район, с. Богатое" FontSize="13" Foreground="#95a5a6" TextAlignment="Center" Margin="0,20,0,0"/>

            <Border Background="#f8f9fa" CornerRadius="10" Padding="20" Margin="0,25,0,0" Height="207">
                <StackPanel>
                    <TextBlock Text="Возможности системы:" FontSize="14" FontWeight="Bold" Foreground="#2c3e50" Margin="0,0,0,12"/>
                    <TextBlock Text="- Управление товарами и категориями" FontSize="13" Foreground="#555"/>
                    <TextBlock Text="- Продажа товаров с поддержкой чека" FontSize="13" Foreground="#555" Margin="0,5,0,0"/>
                    <TextBlock Text="- Отложенные заказы" FontSize="13" Foreground="#555" Margin="0,5,0,0"/>
                    <TextBlock Text="- Возвраты товаров" FontSize="13" Foreground="#555" Margin="0,5,0,0"/>
                    <TextBlock Text="- Отчеты по продажам" FontSize="13" Foreground="#555" Margin="0,5,0,0"/>
                    <TextBlock Text="- Управление поставками" FontSize="13" Foreground="#555" Margin="0,5,0,0"/>
                    <TextBlock Text="- Контроль сроков годности" FontSize="13" Foreground="#555" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>